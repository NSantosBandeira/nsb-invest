# Desenvolvimento local (npm run dev + postgres no Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invest?schema=public"

# Docker Compose (app + postgres): use docker compose up --build
# A app recebe DATABASE_URL automaticamente apontando para o serviço "postgres".

# Gere com: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# Sessão de autenticação (em minutos)
# SESSION_MAX_AGE_MINUTES=480
# SESSION_IDLE_TIMEOUT_MINUTES=30

# URL da aplicação (obrigatório em produção/Docker)
# Local: http://localhost:3000
# Rede (colegas pelo IP): http://SEU_IP:3000  — rode npm run lan:url para ver o IP
AUTH_URL="http://localhost:3000"

# Necessário em Docker / atrás de proxy / acesso por IP na LAN
AUTH_TRUST_HOST="true"

# Fonte de cotações e DY: auto | investidor10 | brapi
# auto = Investidor10 (padrão); com BRAPI_TOKEN tenta Brapi e completa no Investidor10
MARKET_DATA_PROVIDER="auto"

# Opcional: token Brapi (https://brapi.dev) — usado quando MARKET_DATA_PROVIDER=auto ou brapi
# BRAPI_TOKEN=""

# Opcional: CDI anual (% a.a.) se a API do BCB falhar — padrão ~14,9
# CDI_ANNUAL_PERCENT="14.9"
